        <mxCell id="8U9ICg_snljmnY2mWMtf-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;" value="Past experiences have shaped how you see exercise, and none of them stuck." vertex="1">
