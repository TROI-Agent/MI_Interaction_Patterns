        <mxCell id="pViNBNVhqCFvwqN5X0_--1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6EAF8;" value="You&#39;ve heard how activity connects to your prediabetes. What are your thoughts on that?" vertex="1">
          <mxGeometry height="80" width="120" x="365" y="30" as="geometry" />
        </mxCell>
        <mxCell id="V4TyW3bnL5fYn6XjLnFZ-1" edge="1" parent="1" source="8U9ICg_snljmnY2mWMtf-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" target="-_V3FhPgV9P0Oavuqn4L-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="8U9ICg_snljmnY2mWMtf-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;" value="It sounds like staying active at work feels like it should be enough, and hearing otherwise is surprising." vertex="1">
          <mxGeometry height="90" width="120" x="20" y="380" as="geometry" />
        </mxCell>
        <mxCell id="V4TyW3bnL5fYn6XjLnFZ-2" edge="1" parent="1" source="8U9ICg_snljmnY2mWMtf-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="-_V3FhPgV9P0Oavuqn4L-2">
