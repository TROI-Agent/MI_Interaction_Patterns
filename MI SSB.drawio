        </mxCell>
        <mxCell id="8U9ICg_snljmnY2mWMtf-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Being on your feet during the day does help. For your blood sugar to shift, your body needs sustained activity, about 30 minutes at a time, like a brisk walk." vertex="1">
          <mxGeometry height="130" width="136" x="14" y="797.5" as="geometry" />
        </mxCell>
        <mxCell id="V4TyW3bnL5fYn6XjLnFZ-43" edge="1" parent="1" source="8U9ICg_snljmnY2mWMtf-12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" target="N2C2ioZBa7hDYUF-dVrp-2">
