        </mxCell>
        <mxCell id="8U9ICg_snljmnY2mWMtf-6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;" value="Your body has been setting limits on what feels possible, and that&#39;s discouraging." vertex="1">
          <mxGeometry height="60" width="120" x="566" y="380" as="geometry" />
        </mxCell>
        <mxCell id="V4TyW3bnL5fYn6XjLnFZ-6" edge="1" parent="1" source="8U9ICg_snljmnY2mWMtf-7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="-_V3FhPgV9P0Oavuqn4L-6">
