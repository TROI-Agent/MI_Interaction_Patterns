        </mxCell>
        <mxCell id="8U9ICg_snljmnY2mWMtf-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;" value="From where you stand, nothing has signaled a need to do things differently, and that makes sense." vertex="1">
          <mxGeometry height="80" width="120" x="160" y="380" as="geometry" />
        </mxCell>
        <mxCell id="V4TyW3bnL5fYn6XjLnFZ-3" edge="1" parent="1" source="8U9ICg_snljmnY2mWMtf-4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" target="-_V3FhPgV9P0Oavuqn4L-3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="8U9ICg_snljmnY2mWMtf-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;" value="It feels like you&#39;d be going against the grain starting something nobody around you is doing." vertex="1">
          <mxGeometry height="80" width="120" x="296" y="380" as="geometry" />
        </mxCell>
        <mxCell id="V4TyW3bnL5fYn6XjLnFZ-4" edge="1" parent="1" source="8U9ICg_snljmnY2mWMtf-5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="-_V3FhPgV9P0Oavuqn4L-4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="8U9ICg_snljmnY2mWMtf-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;" value="Your days are packed, and fitting one more thing in feels like losing something else." vertex="1">
          <mxGeometry height="90" width="120" x="426" y="380" as="geometry" />
        </mxCell>
        <mxCell id="V4TyW3bnL5fYn6XjLnFZ-5" edge="1" parent="1" source="8U9ICg_snljmnY2mWMtf-6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" target="-_V3FhPgV9P0Oavuqn4L-5">
