            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="8U9ICg_snljmnY2mWMtf-12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Prediabetes usually has no symptoms. Your body feels fine, but your A1C is showing something your body hasn&#39;t told you about yet." vertex="1">
          <mxGeometry height="130" width="120" x="176" y="795" as="geometry" />
        </mxCell>
        <mxCell id="V4TyW3bnL5fYn6XjLnFZ-44" edge="1" parent="1" source="8U9ICg_snljmnY2mWMtf-15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" target="N2C2ioZBa7hDYUF-dVrp-2">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="376" y="960" />
              <mxPoint x="445" y="960" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="8U9ICg_snljmnY2mWMtf-15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="You&#39;re right that most people aren&#39;t active. About 96 million American adults have prediabetes, and most of them don&#39;t know it." vertex="1">
