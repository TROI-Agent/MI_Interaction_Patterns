        <mxCell id="8U9ICg_snljmnY2mWMtf-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="I&#39;d like to share a few things about physical activity and prediabetes, if that&#39;s okay." vertex="1">
          <mxGeometry height="70" width="120" x="376" y="660" as="geometry" />
        </mxCell>
        <mxCell id="V4TyW3bnL5fYn6XjLnFZ-45" edge="1" parent="1" source="8U9ICg_snljmnY2mWMtf-9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" target="N2C2ioZBa7hDYUF-dVrp-2">
