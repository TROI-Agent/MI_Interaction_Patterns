        <mxCell id="889IyH6keWciR2a_tIQm-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="People with routines like yours started by swapping one drink a day and built from there. Research shows cravings for the old drink tend to fade within a few weeks." vertex="1">
          <mxGeometry height="115" width="132" x="431" y="365" as="geometry" />
        </mxCell>
        <mxCell id="8uDJZUloCtly_5dEkOZj-5" edge="1" parent="1" source="889IyH6keWciR2a_tIQm-6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" target="xrFMWszyD4EdzaLMNwVd-22">
