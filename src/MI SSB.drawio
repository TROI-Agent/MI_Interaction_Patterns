        <mxCell id="889IyH6keWciR2a_tIQm-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Some people with A1C numbers like yours who cut back on sugary drinks saw their numbers drop back to a normal range." vertex="1">
