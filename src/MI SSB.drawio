        <mxCell id="V99MnyYNydJ-gA_DM3Ux-45" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F5E3;align=center;" value="&lt;br&gt;Your body feels fine to you, and that&#39;s what you trust more than a number on a lab report.&lt;div&gt;&lt;br/&gt;&lt;/div&gt;" vertex="1">
