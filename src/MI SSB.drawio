        <mxCell id="889IyH6keWciR2a_tIQm-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="It may seem like everyone around you drinks sugary beverages, but sugar sweetened beverage consumption is very rare among those who avoid diabetes." vertex="1">
          <mxGeometry height="130" width="122" x="290" y="350" as="geometry" />
        </mxCell>
        <mxCell id="8uDJZUloCtly_5dEkOZj-4" edge="1" parent="1" source="889IyH6keWciR2a_tIQm-5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" target="xrFMWszyD4EdzaLMNwVd-22">
